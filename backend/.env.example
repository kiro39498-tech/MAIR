DATA_SOURCE=csv
CSV_DATA_DIR=./data/csv

AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_BASE_URL=http://localhost:8000

# --- Phase 2: Persistence & Notifications ---
DB_PATH=./data/replenishment.db

NOTIFY_EMAIL_TO=manager@example.com
NOTIFY_EMAIL_FROM=agent@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# NOTE: For Gmail, SMTP_PASSWORD must be a 16-character Google "app password"
# (Account -> Security -> App passwords), NOT your normal account password. 
# 2FA must be enabled on the account to generate an app password.
SMTP_USERNAME=agent@example.com
SMTP_PASSWORD=your_16_char_app_password
